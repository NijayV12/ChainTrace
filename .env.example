# CHAINTRACE Environment Configuration
# Copy to .env and fill in values

# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Frontend (dev server)
VITE_API_URL=http://localhost:4000

# Production frontend origin(s), comma-separated
# Example: https://your-app.vercel.app,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Database (Postgres recommended for local dev and production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chaintrace?schema=public

# Blockchain
BLOCKCHAIN_DATA_DIR=./data/chain

# AI / LLM (optional - for reasoning layer only; score is always deterministic)
OPENAI_API_KEY=
LLM_REASONING_ENABLED=false

# Optional external Python blockchain service
# e.g. http://localhost:5001 if you run the FastAPI blockchain
PY_BLOCKCHAIN_URL=

# Logging
LOG_LEVEL=info
